# Click First Score merged into a section on /click-first (one-way, no reverse rule)
/score  /click-first  301
/score-result  /click-first  301
/score.html  /click-first  301
/score-result.html  /click-first  301

# OKF rewrites (internal 200)
# Single-file matches (about, case-studies, contact) are NOT rewritten here:
# okf/about.html etc already exist as static files, Cloudflare Pages resolves
# /okf/about -> okf/about.html natively. An explicit rule here collided with
# that native resolution and caused a 308 self-redirect loop.
/okf  /okf/index.html  200
/okf/  /okf/index.html  200
/okf/services  /okf/services/index.html  200
/okf/services/  /okf/services/index.html  200
/okf/services/*  /okf/services/:splat.html  200
/okf/blog  /okf/blog/index.html  200
/okf/blog/  /okf/blog/index.html  200
/okf/blog/*  /okf/blog/:splat.html  200
# Texts rewrites
/texts  /texts/index.txt  200
/texts/  /texts/index.txt  200

/case-studies.html /case-studies/ 301
