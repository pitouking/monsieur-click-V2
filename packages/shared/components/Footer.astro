---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  locale: 'fr' | 'en';
  blurb: string;
  coordsLabel: string;
  coordsNote: string;
  navLabel: string;
  links: NavLink[];
  legal: NavLink[];
  bottom: string;
}

const { blurb, coordsLabel, coordsNote, navLabel, links, legal, bottom } = Astro.props;
---
<footer class="site-footer" role="contentinfo">
  <div class="wrap-wide">
    <div class="foot-grid site-footer__grid">
      <div>
        <a href="#top" class="logo u-logo-foot">
          <img class="mk" src="/logo-mc.webp" alt="Monsieur Click" width="48" height="48" />
          Monsieur <b>Click</b>
        </a>
        <p>{blurb}</p>
      </div>
      <div>
        <p class="foot-label site-footer__label">{coordsLabel}</p>
        <p>24 bis sentier des fosses rouges<br />92240 Malakoff, France</p>
        <p>{coordsNote}</p>
        <!--email_off--><a href="mailto:contact@monsieurclick.com">contact@monsieurclick.com</a><!--/email_off-->
        <a href="tel:+33660761523">+33 6 60 76 15 23</a>
      </div>
      <div>
        <p class="foot-label site-footer__label">{navLabel}</p>
        {links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
    <div class="social">
      <a href="https://www.linkedin.com/company/monsieur-click/" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM0 8h5v16H0zM8 8h4.8v2.2h.07c.67-1.27 2.3-2.6 4.73-2.6 5.06 0 6 3.33 6 7.66V24h-5v-6.9c0-1.65-.03-3.77-2.3-3.77-2.3 0-2.65 1.8-2.65 3.65V24H8z"/></svg>
      </a>
      <a href="https://twitter.com/monsieurclick" target="_blank" rel="noopener" aria-label="X (Twitter)">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.4l-5.8-7.58-6.63 7.58H.49l8.6-9.83L0 1.15h7.6l5.24 6.93zM17.6 20.64h2.04L6.48 3.24H4.3z"/></svg>
      </a>
      <a href="https://www.instagram.com/monsieurclick/" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.12 1.38C1.36 2.67.95 3.34.64 4.13.34 4.9.14 5.77.08 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.15.56 2.92.31.79.72 1.46 1.38 2.12.66.66 1.33 1.07 2.12 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.28-.06 2.15-.26 2.92-.56.79-.31 1.46-.72 2.12-1.38.66-.66 1.07-1.33 1.38-2.12.3-.77.5-1.64.56-2.92.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.15-.56-2.92-.31-.79-.72-1.46-1.38-2.12-.66-.66-1.33-1.07-2.12-1.38-.77-.3-1.64-.5-2.92-.56C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 105.84 12 6.16 6.16 0 0012 5.84zm0 10.16A4 4 0 118 12a4 4 0 014 4zm6.41-10.4a1.44 1.44 0 11-1.44-1.44 1.44 1.44 0 011.44 1.44z"/></svg>
      </a>
    </div>
    <div class="foot-bottom site-footer__bottom">
      {bottom}{' '}
      {legal.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</footer>
