---
import BaseLayout from '@mc/shared/layouts/BaseLayout.astro';
import { locale, nav, footer } from '../chrome.ts';
import bodyHtml from '../../content/404.html?raw';

const title = "Page Not Found | Monsieur Click";
const description = "This page does not exist. Return to Monsieur Click or book a free SEO diagnostic near Paris.";
const canonical = "";
const hreflang = [];
const ogImage = undefined;
const jsonLd = [];
const scripts = ["/shared.js?v=20260719astro","/perf.js?v=20260719astro"];
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonical}
  hreflang={hreflang}
  ogImage={ogImage}
  jsonLd={jsonLd}
  scripts={scripts}
  nav={nav}
  footer={footer}
>
  <Fragment set:html={bodyHtml} />
</BaseLayout>
