const jsonLd = ["{\"@context\":\"https://schema.org\",\"@type\":\"OfferCatalog\",\"name\":\"Click First™ plans\",\"url\":\"https://monsieurclick.com/pricing\",\n\"itemListElement\":[\n{\"@type\":\"Offer\",\"name\":\"Click First™ Essential\",\"priceCurrency\":\"EUR\",\"price\":\"850\",\"description\":\"Small site or solo coach, 6-month commitment.\"},\n{\"@type\":\"Offer\",\"name\":\"Click First™ Growth\",\"priceCurrency\":\"EUR\",\"price\":\"1000\",\"description\":\"Tradesperson site, 12-month commitment.\"},\n{\"@type\":\"Offer\",\"name\":\"Click First™ Expansion\",\"priceCurrency\":\"EUR\",\"price\":\"1500\",\"description\":\"Company site, 12-month commitment.\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is the price really all-inclusive?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. The price covers the complete ecosystem: website, GBP, AI visibility and monthly optimization. No stacked packages, no hidden costs.\"}},{\"@type\":\"Question\",\"name\":\"Why a 6 or 12-month commitment?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Lasting visibility is built over time. The commitment matches the time needed for the method to produce solid results, measured each month.\"}},{\"@type\":\"Question\",\"name\":\"What happens after the setup subscription?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Once the 6 or 12 months are over, you're not required to keep the same level of support. You can continue with ongoing SEO optimization at a lower rate, or switch to hosting and maintenance only, at €59/month.\"}},{\"@type\":\"Question\",\"name\":\"How is the final price set?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"After the free audit, based on your area, your competition and your goals. You know exactly what you pay, with no surprises.\"}},{\"@type\":\"Question\",\"name\":\"Which Click First™ plan should a small local business choose?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The right plan depends on your scale, not your industry. Essential covers one city and one to three services, Growth two to three cities, Expansion a multi-city rollout. The free audit identifies the right scale based on your real competition on Google and Google Maps.\"}},{\"@type\":\"Question\",\"name\":\"Are local SEO and AI visibility included in every plan?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Local organic SEO, Google Business Profile, Google reviews, NAP consistency, Schema.org structured data and the GEO framework for ChatGPT, Claude, Gemini and Perplexity are in the foundation of all three plans. Only the deployment scope changes.\"}},{\"@type\":\"Question\",\"name\":\"Can I change plans along the way?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Many clients start with Essential then move up once the first results are in place. The Click First™ method stays the same, only its scope grows with your business.\"}},{\"@type\":\"Question\",\"name\":\"Are there setup fees or hidden costs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. The monthly price is all-inclusive, with no stacked packages or surprise fees. There's no online payment: the precise quote is set after your free audit.\"}},{\"@type\":\"Question\",\"name\":\"How long before I see results on Google Maps?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Local SEO shows its first signals in two to three months; a solid position consolidates over four to six months. We guarantee no position: results are built over time and measured every month.\"}},{\"@type\":\"Question\",\"name\":\"What's the difference between Click First™ and a traditional web agency?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We don't deliver a site and disappear. The monthly price funds a living ecosystem where your website, local SEO, Google Business Profile, Google reviews and presence in AI engines work together and reinforce each other, month after month.\"}},{\"@type\":\"Question\",\"name\":\"Is CRM automation included in the price?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. CRM automation (booking, lead tracking and follow-ups) is an add-on outside the core, enabled only if your contact volume justifies it.\"}}]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.com/#org\",\"name\":\"Monsieur Click\",\"alternateName\":\"Creator of Click First™\",\"url\":\"https://monsieurclick.com/\",\"logo\":\"https://monsieurclick.com/logo-mc.webp\",\"image\":\"https://monsieurclick.com/hero-mc-paris.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"priceRange\":\"€€\",\"foundingDate\":\"2023\",\"knowsLanguage\":[\"fr\",\"en\"],\"founder\":{\"@type\":\"Person\",\"name\":\"Jean-Pierre Baguette\"},\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des Fosses Rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgium\"},{\"@type\":\"Country\",\"name\":\"Switzerland\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\"sameAs\":[\"https://www.linkedin.com/company/monsieur-click/\",\"https://twitter.com/monsieurclick\",\"https://www.instagram.com/monsieurclick/\",\"https://facebook.com/monsieurclick\"]},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.com/#website\",\"url\":\"https://monsieurclick.com/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"en-US\",\"publisher\":{\"@id\":\"https://monsieurclick.com/#org\"}}\n]}","{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"WebPage\", \"@id\": \"https://monsieurclick.com/pricing#webpage\", \"url\": \"https://monsieurclick.com/pricing\", \"name\": \"Click First™ pricing and plans | Monsieur Click\", \"isPartOf\": {\"@id\": \"https://monsieurclick.com/#website\"}, \"about\": {\"@id\": \"https://monsieurclick.com/#org\"}, \"inLanguage\": \"en-US\", \"description\": \"One method, at your scale: Essential from €850/month, Growth €1,000/month, Expansion €1,500/month. Website, SEO, GBP, AI visibility and monthly optimization included.\", \"breadcrumb\": {\"@id\": \"https://monsieurclick.com/pricing#breadcrumb\"}}, {\"@type\": \"BreadcrumbList\", \"@id\": \"https://monsieurclick.com/pricing#breadcrumb\", \"itemListElement\": [{\"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://monsieurclick.com/\"}, {\"@type\": \"ListItem\", \"position\": 2, \"name\": \"Pricing\", \"item\": \"https://monsieurclick.com/pricing\"}]}]}"];
const scripts = [{"src":"/perf.js?v=20260719astro","module":false},{"src":"/shared.js?v=20260719astro","module":false}];
