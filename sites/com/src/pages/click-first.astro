const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Click First™\",\n  \"serviceType\":\"Visibility system: website and Technical SEO, local SEO, Google Business Profile, NAP citations, reviews, Schema.org and OKF structured data, GEO (AI visibility) and continuous optimization\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.com\"},\n  \"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgium\"},{\"@type\":\"Country\",\"name\":\"Switzerland\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\n  \"offers\":{\"@type\":\"Offer\",\"priceCurrency\":\"EUR\",\"price\":\"850\",\"description\":\"Click First™ from €850/month, 6-month commitment.\"}\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://monsieurclick.com/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Click First™\",\"item\":\"https://monsieurclick.com/click-first\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"Can I take just one component?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Click First™ method is designed to make every lever work together. It is this coherence between website, local SEO, Google Business Profile, reviews and AI visibility that produces the best results.\"}},\n{\"@type\":\"Question\",\"name\":\"What is Schema and OKF development?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Schema.org markup describes your business in a language Google understands. OKF (Open Knowledge Format) goes further by structuring your knowledge for AI engines, so that ChatGPT, Claude, Gemini and Perplexity can cite you accurately.\"}},\n{\"@type\":\"Question\",\"name\":\"Is Technical SEO included?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Loading speed, Core Web Vitals, mobile-first, architecture and internal linking, canonicals and sitemap are all part of building the site.\"}},\n{\"@type\":\"Question\",\"name\":\"What is NAP consistency?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"NAP stands for Name, Address, Phone. Google trusts a business more when this information is identical everywhere: website, Google profile and local directories. We align your local citations.\"}},\n{\"@type\":\"Question\",\"name\":\"How long until results show?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Local SEO often shows first signals within 2 to 3 months; a solid position is built over 4 to 6 months, depending on your industry and competition.\"}},\n{\"@type\":\"Question\",\"name\":\"Does Click First™ work with WordPress?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We adapt our stack to each case as needed: WordPress, Brizy Cloud, an AI-managed static site or a dynamic site. Whatever the platform, Technical SEO, Schema.org structured data, internal linking and the sitemap are built in.\"}},\n{\"@type\":\"Question\",\"name\":\"How do I get cited by ChatGPT, Gemini and Perplexity?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"That is the role of GEO (Generative Engine Optimization): clear, citable content, Schema.org structured data and an OKF / llms.txt bundle, consistent named entities, and allowing AI crawlers (GPTBot, ClaudeBot, PerplexityBot, Google-Extended).\"}},\n{\"@type\":\"Question\",\"name\":\"What is the difference between SEO and GEO?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Organic SEO targets your ranking on Google and Google Maps. GEO targets your presence in the answers of AI engines like ChatGPT, Claude, Gemini and Perplexity. Click First™ handles both together, because they rely on the same foundations.\"}},\n{\"@type\":\"Question\",\"name\":\"Do I need to rebuild my site to apply Click First™?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Not necessarily. We start with an audit. If your Technical SEO and Core Web Vitals allow it, we optimize what exists. A rebuild is only proposed when it is truly needed.\"}},\n{\"@type\":\"Question\",\"name\":\"How do I appear in the Google Maps local pack?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The local pack shows the three most relevant profiles. We work toward it with an optimized Google Business Profile, a Google reviews strategy, NAP consistency across your citations and an aligned website, across Google's three criteria: proximity, relevance and prominence.\"}},\n{\"@type\":\"Question\",\"name\":\"Do you work remotely, across France and internationally?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, 100% remotely (phone, Zoom, email), across French-speaking countries (France, Belgium, Switzerland, Canada) and English-speaking countries (United States, United Kingdom).\"}},\n{\"@type\":\"Question\",\"name\":\"Does Click First™ guarantee the number one spot on Google?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. No serious method can guarantee a position: Google and AI engines change their algorithms without notice. We build lasting visibility, measured each month with a transparent KPI report.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.com/#org\",\"name\":\"Monsieur Click\",\"alternateName\":\"Creator of Click First™\",\"url\":\"https://monsieurclick.com/\",\"logo\":\"https://monsieurclick.com/logo-mc.webp\",\"image\":\"https://monsieurclick.com/hero-mc-paris.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"priceRange\":\"€€\",\"foundingDate\":\"2023\",\"knowsLanguage\":[\"fr\",\"en\"],\"founder\":{\"@type\":\"Person\",\"name\":\"Jean-Pierre Baguette\"},\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des Fosses Rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgium\"},{\"@type\":\"Country\",\"name\":\"Switzerland\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\"sameAs\":[\"https://www.linkedin.com/company/monsieur-click/\",\"https://twitter.com/monsieurclick\",\"https://www.instagram.com/monsieurclick/\",\"https://facebook.com/monsieurclick\"]},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.com/#website\",\"url\":\"https://monsieurclick.com/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"en-US\",\"publisher\":{\"@id\":\"https://monsieurclick.com/#org\"}}\n]}","{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"WebPage\", \"@id\": \"https://monsieurclick.com/click-first#webpage\", \"url\": \"https://monsieurclick.com/click-first\", \"name\": \"Click First™: the all-in-one SEO + AI method (website, Google Business Profile, GEO) | Monsieur Click\", \"isPartOf\": {\"@id\": \"https://monsieurclick.com/#website\"}, \"about\": {\"@id\": \"https://monsieurclick.com/#org\"}, \"inLanguage\": \"en-US\", \"description\": \"Click First™ brings together website and Technical SEO, local organic SEO, Google Business Profile, NAP citations, Google reviews, Schema.org and OKF structured data, AI visibility (GEO) and continuous optimization in one coherent method.\"}]}"];
