---
import BaseLayout from '@mc/shared/layouts/BaseLayout.astro';
import { locale, nav, footer } from '../chrome.ts';
import bodyHtml from '../../content/offres.html?raw';

const title = "Tarifs SEO local dès 850€/mois | Monsieur Click";
const description = "Offres Click First™ pour TPE/PME : site, SEO local et GBP dès 850€/mois, sans surprise. 100% à distance. Note 5/5 sur 15 avis. Diagnostic gratuit.";
const canonical = "https://monsieurclick.fr/offres";
const hreflang = [{"lang":"fr","href":"https://monsieurclick.fr/offres"},{"lang":"en","href":"https://monsieurclick.com/pricing"},{"lang":"x-default","href":"https://monsieurclick.fr/offres"}];
const ogImage = undefined;
const jsonLd = ["{\"@context\":\"https://schema.org\",\"@type\":\"OfferCatalog\",\"name\":\"Offres Click First™\",\"url\":\"https://monsieurclick.fr/offres\",\n\"itemListElement\":[\n{\"@type\":\"Offer\",\"name\":\"Click First™ Essentiel\",\"priceCurrency\":\"EUR\",\"price\":\"850\",\"description\":\"Site petit ou coach, engagement 6 mois.\"},\n{\"@type\":\"Offer\",\"name\":\"Click First™ Développement\",\"priceCurrency\":\"EUR\",\"price\":\"1000\",\"description\":\"Site artisan, engagement 12 mois.\"},\n{\"@type\":\"Offer\",\"name\":\"Click First™ Expansion\",\"priceCurrency\":\"EUR\",\"price\":\"1500\",\"description\":\"Site entreprise, engagement 12 mois.\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Le prix est-il vraiment tout inclus ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Le tarif couvre l'écosystème complet : site, GBP, visibilité IA et optimisation mensuelle. Pas de packs empilés, pas de coûts cachés.\"}},{\"@type\":\"Question\",\"name\":\"Pourquoi un engagement de 6 ou 12 mois ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La visibilité durable se construit dans le temps. L'engagement correspond à la durée nécessaire pour que la méthode produise des résultats solides, mesurés chaque mois.\"}},{\"@type\":\"Question\",\"name\":\"Que se passe-t-il après l'abonnement de mise en place ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Une fois les 6 ou 12 mois terminés, vous n'êtes pas obligé de conserver le même niveau d'accompagnement. Vous pouvez poursuivre avec une optimisation SEO permanente à tarif inférieur, ou basculer sur l'hébergement et la maintenance uniquement, à 59 €/mois.\"}},{\"@type\":\"Question\",\"name\":\"Comment est fixé le prix final ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Après le diagnostic gratuit, selon votre zone, votre concurrence et vos objectifs. Vous savez exactement ce que vous payez, sans surprise.\"}},{\"@type\":\"Question\",\"name\":\"Quelle offre Click First™ choisir pour une petite entreprise locale ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le bon plan dépend de votre échelle, pas de votre secteur. Essentiel couvre une ville et un à trois services, Développement deux à trois villes, Expansion un déploiement multi-villes. Le diagnostic gratuit identifie la bonne échelle à partir de votre concurrence réelle sur Google et Google Maps.\"}},{\"@type\":\"Question\",\"name\":\"Le SEO local et la visibilité IA sont-ils inclus dans toutes les offres ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Référencement naturel local, Google Business Profile, avis Google, cohérence NAP, données structurées Schema.org et framework GEO pour ChatGPT, Claude, Gemini et Perplexity sont dans le socle des trois offres. Seule l'ampleur du déploiement change.\"}},{\"@type\":\"Question\",\"name\":\"Puis-je changer d'offre en cours de route ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Beaucoup de clients démarrent en Essentiel puis montent en gamme une fois les premiers résultats installés. La méthode Click First™ reste identique, seule sa portée grandit avec votre entreprise.\"}},{\"@type\":\"Question\",\"name\":\"Y a-t-il des frais de mise en route ou des coûts cachés ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Le tarif mensuel est tout inclus, sans packs empilés ni frais surprise. Il n'y a aucun paiement en ligne : le chiffrage précis est établi après votre diagnostic gratuit.\"}},{\"@type\":\"Question\",\"name\":\"Combien de temps avant de voir des résultats sur Google Maps ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le référencement local donne ses premiers signaux en deux à trois mois, une position solide se consolide sur quatre à six mois. Nous ne garantissons aucune position : les résultats se construisent dans le temps et sont mesurés chaque mois.\"}},{\"@type\":\"Question\",\"name\":\"Quelle différence entre Click First™ et une agence web classique ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"On ne vous livre pas un site puis on disparaît. Le prix mensuel finance un écosystème vivant où votre site internet, votre SEO local, votre fiche Google Business Profile, vos avis Google et votre présence dans les moteurs IA travaillent ensemble et se renforcent, mois après mois.\"}},{\"@type\":\"Question\",\"name\":\"L'automatisation CRM est-elle comprise dans le prix ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. L'automatisation CRM (prise de rendez-vous, suivi et relance des leads) est une option hors socle, activée uniquement si votre volume de contacts le justifie.\"}}]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"alternateName\":\"Créateur de Click First™\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"image\":\"https://monsieurclick.fr/hero-mc-paris.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"priceRange\":\"€€\",\"foundingDate\":\"2023\",\"knowsLanguage\":[\"fr\",\"en\"],\"founder\":{\"@type\":\"Person\",\"name\":\"Jean-Pierre Baguette\",\"jobTitle\":\"Fondateur\",\"description\":\"10 ans d'expérience en SEO et visibilité locale.\"},\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des Fosses Rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\"sameAs\":[\"https://www.linkedin.com/company/monsieur-click/\",\"https://twitter.com/monsieurclick\",\"https://www.instagram.com/monsieurclick/\"]},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}","{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"WebPage\", \"@id\": \"https://monsieurclick.fr/offres#webpage\", \"url\": \"https://monsieurclick.fr/offres\", \"name\": \"Offres et tarifs Click First™ | Monsieur Click\", \"isPartOf\": {\"@id\": \"https://monsieurclick.fr/#website\"}, \"about\": {\"@id\": \"https://monsieurclick.fr/#org\"}, \"inLanguage\": \"fr-FR\", \"description\": \"Une seule méthode, à votre échelle : Essentiel dès 850 €/mois, Développement 1 000 €/mois, Expansion 1 500 €/mois. Site, SEO, GBP, visibilité IA et optimisation mensuelle inclus.\", \"breadcrumb\": {\"@id\": \"https://monsieurclick.fr/offres#breadcrumb\"}}, {\"@type\": \"BreadcrumbList\", \"@id\": \"https://monsieurclick.fr/offres#breadcrumb\", \"itemListElement\": [{\"@type\": \"ListItem\", \"position\": 1, \"name\": \"Accueil\", \"item\": \"https://monsieurclick.fr/\"}, {\"@type\": \"ListItem\", \"position\": 2, \"name\": \"Offres\", \"item\": \"https://monsieurclick.fr/offres\"}]}]}"];
const scripts = [{"src":"/perf.js?v=20260719astro","module":false},{"src":"/shared.js?v=20260719astro","module":false}];
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonical}
  hreflang={hreflang}
  ogImage={ogImage}
  jsonLd={jsonLd}
  scripts={scripts}
  nav={nav}
  footer={footer}
>
  <Fragment set:html={bodyHtml} />
</BaseLayout>
