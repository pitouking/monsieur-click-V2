const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Click First™\",\n  \"serviceType\":\"Système de visibilité : site web et Technical SEO, SEO local, Google Business Profile, citations NAP, avis, données structurées Schema.org et OKF, GEO (visibilité IA), optimisation continue\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.com\"},\n  \"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\n  \"offers\":{\"@type\":\"Offer\",\"priceCurrency\":\"EUR\",\"price\":\"850\",\"description\":\"Click First™ à partir de 850 €/mois, engagement 6 mois.\"}\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://monsieurclick.fr/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Click First™\",\"item\":\"https://monsieurclick.fr/click-first\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"Puis-je ne prendre qu'une seule composante ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La méthode Click First™ est conçue pour faire travailler tous les leviers ensemble. C'est cette cohérence entre site, SEO local, Google Business Profile, avis et visibilité IA qui produit les meilleurs résultats.\"}},\n{\"@type\":\"Question\",\"name\":\"Qu'est-ce que le développement de Schema et d'OKF ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le balisage Schema.org décrit votre entreprise dans un langage que Google comprend. L'OKF (Open Knowledge Format) va plus loin en structurant vos connaissances pour les moteurs IA, afin que ChatGPT, Claude, Gemini et Perplexity puissent vous citer avec précision.\"}},\n{\"@type\":\"Question\",\"name\":\"Le Technical SEO est-il inclus ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Vitesse de chargement, Core Web Vitals, mobile-first, architecture et maillage interne, canonicals et sitemap font partie de la construction du site.\"}},\n{\"@type\":\"Question\",\"name\":\"Qu'est-ce que la cohérence NAP ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"NAP signifie Nom, Adresse, Téléphone. Google fait davantage confiance à une entreprise dont ces informations sont identiques partout : site, fiche Google et annuaires locaux. Nous alignons vos citations locales.\"}},\n{\"@type\":\"Question\",\"name\":\"En combien de temps voit-on des résultats ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le SEO local donne souvent des premiers signaux en 2 à 3 mois, une position solide se construit sur 4 à 6 mois, selon votre secteur et votre concurrence.\"}},\n{\"@type\":\"Question\",\"name\":\"Click First™ fonctionne-t-il avec WordPress ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nous adaptons notre stack à chaque cas indépendant suivant les besoins. Ça peut être WordPress, Brizy Cloud, un site statique géré par l'IA, un site dynamique. Quoi qu'il arrive, nous sommes au top à chaque fois. Le Technical SEO, les données structurées Schema.org, le maillage interne et le sitemap sont intégrés quelle que soit la plateforme.\"}},\n{\"@type\":\"Question\",\"name\":\"Comment être cité par ChatGPT, Gemini et Perplexity ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"C'est le rôle du GEO (Generative Engine Optimization) : des contenus clairs et citables, des données structurées Schema.org et un bundle OKF / llms.txt, des entités nommées cohérentes, et l'autorisation des robots IA (GPTBot, ClaudeBot, PerplexityBot, Google-Extended).\"}},\n{\"@type\":\"Question\",\"name\":\"Quelle différence entre le SEO et le GEO ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le référencement naturel (SEO) vise votre classement sur Google et Google Maps. Le GEO vise votre présence dans les réponses des moteurs IA comme ChatGPT, Claude, Gemini et Perplexity. Click First™ traite les deux ensemble, car ils s'appuient sur les mêmes fondations.\"}},\n{\"@type\":\"Question\",\"name\":\"Faut-il refaire mon site pour appliquer Click First™ ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pas systématiquement. On commence par un audit. Si votre Technical SEO et vos Core Web Vitals le permettent, on optimise l'existant. Une refonte n'est proposée que lorsqu'elle est réellement nécessaire.\"}},\n{\"@type\":\"Question\",\"name\":\"Comment apparaître dans le pack local de Google Maps ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le pack local affiche les trois fiches les plus pertinentes. On y travaille par un Google Business Profile optimisé, une stratégie d'avis Google, la cohérence NAP de vos citations et un site aligné, sur les trois critères de Google : proximité, pertinence et notoriété.\"}},\n{\"@type\":\"Question\",\"name\":\"Travaillez-vous à distance, partout en France et à l'international ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui, 100 % à distance (téléphone, Zoom, email), dans les pays francophones (France, Belgique, Suisse, Canada) et anglophones (États-Unis, Royaume-Uni).\"}},\n{\"@type\":\"Question\",\"name\":\"Click First™ garantit-il la première position sur Google ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Aucune méthode sérieuse ne peut garantir une position : Google et les moteurs IA changent leurs algorithmes sans préavis. Nous construisons une visibilité durable, mesurée chaque mois avec un rapport KPI transparent.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"alternateName\":\"Créateur de Click First™\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"image\":\"https://monsieurclick.fr/hero-mc-paris.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"priceRange\":\"€€\",\"foundingDate\":\"2023\",\"knowsLanguage\":[\"fr\",\"en\"],\"founder\":{\"@type\":\"Person\",\"name\":\"Jean-Pierre Baguette\",\"jobTitle\":\"Fondateur\",\"description\":\"10 ans d'expérience en SEO et visibilité locale.\"},\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des Fosses Rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"}],\"sameAs\":[\"https://www.linkedin.com/company/monsieur-click/\",\"https://twitter.com/monsieurclick\",\"https://www.instagram.com/monsieurclick/\"]},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}","{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"WebPage\", \"@id\": \"https://monsieurclick.fr/click-first#webpage\", \"url\": \"https://monsieurclick.fr/click-first\", \"name\": \"Click First™ : la méthode SEO + IA tout-en-un (site, Google Business Profile, GEO) | Monsieur Click\", \"isPartOf\": {\"@id\": \"https://monsieurclick.fr/#website\"}, \"about\": {\"@id\": \"https://monsieurclick.fr/#org\"}, \"inLanguage\": \"fr-FR\", \"description\": \"Click First™ réunit site internet et Technical SEO, référencement naturel local, Google Business Profile, citations NAP, avis Google, données structurées Schema.org et OKF, visibilité IA (GEO) et optimisation continue dans une seule méthode cohérente.\"}]}"];
const scripts = [{"src":"/perf.js?v=20260719perf","module":false},{"src":"/shared.js?v=20260719perf","module":false},{"src":"/score-embed.js","module":true},{"src":"/webmcp.js?v=20260719agent","module":false}];
---
