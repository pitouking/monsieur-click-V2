const canonical = "https://monsieurclick.fr/services/seo";
const hreflang = [{"lang":"fr-fr","href":"https://monsieurclick.fr/services/seo"},{"lang":"fr-be","href":"https://monsieurclick.fr/services/seo"},{"lang":"fr-ch","href":"https://monsieurclick.fr/services/seo"},{"lang":"en-us","href":"https://monsieurclick.com/services/seo"},{"lang":"en-gb","href":"https://monsieurclick.com/services/seo"},{"lang":"x-default","href":"https://monsieurclick.com/services/seo"}];
const ogImage = undefined;
const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\n  \"name\":\"Référencement naturel (SEO)\",\n  \"serviceType\":\"SEO technique, on-page et de contenu pour TPE et PME\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr\"},\n  \"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"}],\n  \"description\":\"Référencement naturel pour entreprises locales : audit, optimisation technique, contenu et reporting mensuel.\"\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://monsieurclick.fr/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://monsieurclick.fr/services/\"},\n{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Référencement naturel (SEO)\",\"item\":\"https://monsieurclick.fr/services/seo\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"C'est quoi une agence SEO ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Une agence SEO accompagne les entreprises pour améliorer leur visibilité sur Google via le référencement naturel : optimisation technique du site, contenu pertinent et autorité. Contrairement à la publicité payante, le SEO construit un trafic durable sans payer chaque clic.\"}},\n{\"@type\":\"Question\",\"name\":\"Combien de temps faut-il pour voir des résultats en SEO ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Les premiers signaux apparaissent souvent en 2 à 3 mois. Une position solide se construit sur 4 à 6 mois, selon votre secteur et la concurrence. Nous mesurons la progression chaque mois avec un rapport KPI transparent.\"}},\n{\"@type\":\"Question\",\"name\":\"Quelle différence entre SEO et Google Ads ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Google Ads génère du trafic immédiat mais s'arrête dès que vous cessez de payer. Le référencement naturel construit une visibilité durable : une fois bien positionné, vous recevez des visites sans coût par clic. Les deux peuvent coexister, mais le SEO est l'investissement long terme.\"}},\n{\"@type\":\"Question\",\"name\":\"Le SEO inclut-il le référencement local ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le SEO local est une branche du référencement naturel focalisée sur Google Maps et le pack local. Nous proposons un service dédié SEO local, complémentaire au référencement naturel global.\"}},\n{\"@type\":\"Question\",\"name\":\"Garantissez-vous la première position sur Google ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Aucune agence sérieuse ne peut garantir une position : Google change ses algorithmes sans préavis. Nous construisons une visibilité durable et mesurable, avec un reporting mensuel honnête sur ce qui progresse.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des fosses rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"}},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}"];
const scripts = [{"src":"/perf.js?v=20260719astro","module":false},{"src":"/shared.js?v=20260719astro","module":false}];
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonical}
  hreflang={hreflang}
  ogImage={ogImage}
  jsonLd={jsonLd}
  scripts={scripts}
  nav={nav}
  footer={footer}
>
  <Fragment set:html={bodyHtml} />
</BaseLayout>
