const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\n  \"name\":\"Visibilité IA (GEO)\",\n  \"serviceType\":\"Generative Engine Optimization : optimisation pour ChatGPT, Gemini, Perplexity et AI Overviews\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr\"},\n  \"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"}],\n  \"description\":\"GEO pour TPE et PME : données structurées Schema.org, bundle OKF, llms.txt, contenus citables et configuration crawlers IA (GPTBot, ClaudeBot, PerplexityBot).\"\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://monsieurclick.fr/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://monsieurclick.fr/services/\"},\n{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Visibilité IA (GEO)\",\"item\":\"https://monsieurclick.fr/services/visibilite-ia-geo\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"C'est quoi le GEO (Generative Engine Optimization) ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le GEO est l'optimisation de votre présence en ligne pour être cité par les moteurs IA comme ChatGPT, Gemini, Perplexity et Claude. Contrairement au SEO classique qui vise le classement Google, le GEO structure vos contenus, entités et données pour que les IA vous recommandent comme source fiable.\"}},\n{\"@type\":\"Question\",\"name\":\"Qu'est-ce que le fichier llms.txt ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le llms.txt est un fichier à la racine de votre site, à la manière du robots.txt, qui résume votre activité et pointe vers vos pages clés pour les agents IA. Il facilite la découverte et la citation de votre entreprise par ChatGPT, Claude et Perplexity.\"}},\n{\"@type\":\"Question\",\"name\":\"Quel rôle joue Schema.org dans la visibilité IA ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Les données structurées Schema.org (Service, FAQPage, LocalBusiness, Organization) donnent aux IA des faits clairs et vérifiables sur votre entreprise : nom, services, zone, FAQ. C'est la base technique pour être cité avec précision plutôt qu'ignoré ou mal représenté.\"}},\n{\"@type\":\"Question\",\"name\":\"Qu'est-ce que le bundle OKF ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"L'OKF (Open Knowledge Framework) est un bundle de connaissances structurées sur votre entreprise : entités, faits, services, zones desservies. Il alimente les IA avec des informations cohérentes et citables, complémentaires au Schema.org et au llms.txt.\"}},\n{\"@type\":\"Question\",\"name\":\"Le GEO remplace-t-il le SEO ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Le GEO complète le référencement naturel. Google reste central, mais de plus en plus de parcours d'achat commencent par une question posée à une IA. Une stratégie Click First™ combine SEO, SEO local, fiche Google et visibilité IA pour couvrir tous les points d'entrée.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des fosses rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"}},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}"];
const scripts = [{"src":"/perf.js?v=20260719astro","module":false},{"src":"/shared.js?v=20260719astro","module":false}];
