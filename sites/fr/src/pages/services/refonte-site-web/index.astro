const title = "Refonte de site web SEO | Monsieur Click";
const description = "Refonte rapide, mobile et orientée conversion pour TPE/PME en Île-de-France et au-delà. 100% à distance. Note 5/5 sur 15 avis. Diagnostic gratuit.";
const canonical = "https://monsieurclick.fr/services/refonte-site-web";
const hreflang = [{"lang":"fr","href":"https://monsieurclick.fr/services/refonte-site-web"},{"lang":"en","href":"https://monsieurclick.com/services/website-redesign"},{"lang":"x-default","href":"https://monsieurclick.fr/services/refonte-site-web"}];
const ogImage = undefined;
const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\n  \"name\":\"Refonte de site internet\",\n  \"serviceType\":\"Refonte de site web pour TPE et PME : performance, SEO technique, StoryBrand et conversion\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr\"},\n  \"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"}],\n  \"description\":\"Refonte de site internet : audit préalable, reconstruction ou optimisation ciblée, Core Web Vitals au vert, SEO intégré dès la conception.\"\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://monsieurclick.fr/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://monsieurclick.fr/services/\"},\n{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Refonte de site internet\",\"item\":\"https://monsieurclick.fr/services/refonte-site-web\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"Quand faut-il refondre un site internet ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Une refonte est pertinente quand votre site est lent (Core Web Vitals au rouge), mal structuré pour Google, non responsive, ou qu'il ne convertit pas les visiteurs en contacts. Si une optimisation ciblée suffit, nous le disons honnêtement lors du diagnostic.\"}},\n{\"@type\":\"Question\",\"name\":\"Combien coûte une refonte de site internet ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le budget dépend de la taille du site et de l'ampleur des changements. Une refonte vitrine optimisée SEO démarre autour de 3 000 à 6 000 €. Nous chiffrons après un audit préalable, avec un plan écrit et sans surprise.\"}},\n{\"@type\":\"Question\",\"name\":\"Perdrai-je mes positions Google lors d'une refonte ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pas si la refonte est bien planifiée. Nous mettons en place des redirections 301, conservons les URL stratégiques, migrons les contenus performants et soumettons le nouveau sitemap. Un suivi post-lancement vérifie l'indexation et les positions.\"}},\n{\"@type\":\"Question\",\"name\":\"Refonte ou création de site : quelle différence ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La création part de zéro. La refonte repart d'un site existant : nous auditons ce qui fonctionne, ce qui bloque, et nous reconstruisons ou optimisons en préservant l'autorité SEO acquise. Les deux services partagent la même exigence : performance, SEO et conversion.\"}},\n{\"@type\":\"Question\",\"name\":\"Quelle technologie pour une refonte de site ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nous choisissons la stack selon vos besoins : WordPress si vous voulez éditer vous-même, Brizy Cloud pour un bon compromis design et autonomie, ou statique pour la performance maximale. Dans tous les cas, le SEO technique est intégré dès le départ.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des fosses rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"}},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}"];
const scripts = ["/perf.js?v=20260719astro","/shared.js?v=20260719astro"];
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonical}
  hreflang={hreflang}
  ogImage={ogImage}
  jsonLd={jsonLd}
  scripts={scripts}
  nav={nav}
  footer={footer}
>
  <Fragment set:html={bodyHtml} />
</BaseLayout>
