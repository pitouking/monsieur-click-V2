const jsonLd = ["{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\"@type\":\"Question\",\"name\":\"Comment apparaître dans le top 3 de Google Maps ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"En envoyant à Google les bons signaux de proximité, de notoriété et de pertinence : une fiche Google Business Profile complète, des avis réguliers, un site cohérent et des contenus locaux. Nous orchestrons tout cela ensemble avec Click First™.\"}},\n    {\"@type\":\"Question\",\"name\":\"Comment être référencé sur Google gratuitement ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Une fiche Google Business Profile et un site optimisé peuvent vous rendre visible sans publicité. Le référencement naturel prend du temps mais construit une visibilité durable.\"}},\n    {\"@type\":\"Question\",\"name\":\"Faut-il un site internet si j'ai déjà une fiche Google Business Profile ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. La fiche est souvent le premier contact, mais le site rassure, convertit et alimente les moteurs et les IA en informations. Les deux se renforcent mutuellement.\"}},\n    {\"@type\":\"Question\",\"name\":\"Comment être recommandé par ChatGPT ou les intelligences artificielles ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Les IA s'appuient sur les informations disponibles sur le web : contenus clairs, données structurées, avis et cohérence de vos informations. Nous préparons votre présence pour qu'elles puissent vous citer.\"}},\n    {\"@type\":\"Question\",\"name\":\"Combien de temps faut-il pour être visible sur Google ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le SEO local donne souvent des premiers signaux en 2 à 3 mois. Une position solide se construit sur 4 à 6 mois selon votre secteur et votre concurrence.\"}},\n    {\"@type\":\"Question\",\"name\":\"Qu'est-ce que le SEO local ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"C'est l'ensemble des actions qui rendent une entreprise visible pour les recherches géolocalisées. Il combine fiche Google, avis, site et contenus locaux.\"}},\n    {\"@type\":\"Question\",\"name\":\"Travaillez-vous avec des entreprises francophones et anglophones ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Nous accompagnons des entreprises dans tous les pays francophones et anglophones, en français comme en anglais, sans aucune barrière de langue.\"}},\n    {\"@type\":\"Question\",\"name\":\"Est-ce que le SEO est mort avec les intelligences artificielles ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Le référencement naturel évolue, il ne meurt pas. Les moteurs IA comme ChatGPT, Gemini et Perplexity s'appuient sur les mêmes fondations que Google : un contenu clair, des données structurées Schema.org, des avis et des informations cohérentes. Bien fait, le SEO nourrit directement votre visibilité dans les IA (le GEO).\"}},\n    {\"@type\":\"Question\",\"name\":\"Pourquoi investir maintenant plutôt que dans un an ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Parce que la visibilité se construit dans le temps, et que vos concurrents avancent déjà. Chaque mois d'attente laisse la place libre sur Google, Google Maps et dans les réponses des IA. Commencer tôt, c'est capitaliser une autorité que les nouveaux entrants devront ensuite rattraper.\"}}\n  ]\n}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\",\"LocalBusiness\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"alternateName\":\"Créateur de Click First™\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"image\":\"https://monsieurclick.fr/hero-mc-paris.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"priceRange\":\"€€\",\"foundingDate\":\"2023\",\"knowsLanguage\":[\"fr\",\"en\"],\"founder\":{\"@id\":\"https://monsieurclick.fr/#person\"},\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des Fosses Rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":48.8167,\"longitude\":2.2997},\"areaServed\":[{\"@type\":\"Country\",\"name\":\"France\"},{\"@type\":\"Country\",\"name\":\"Belgique\"},{\"@type\":\"Country\",\"name\":\"Suisse\"},{\"@type\":\"Country\",\"name\":\"Canada\"},{\"@type\":\"Country\",\"name\":\"United States\"},{\"@type\":\"Country\",\"name\":\"United Kingdom\"},{\"@type\":\"City\",\"name\":\"Paris\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Île-de-France\"}],\"sameAs\":[\"https://www.linkedin.com/company/monsieur-click/\",\"https://twitter.com/monsieurclick\",\"https://www.instagram.com/monsieurclick/\"]},\n{\"@type\":\"Person\",\"@id\":\"https://monsieurclick.fr/#person\",\"name\":\"Jean-Pierre Baguette\",\"jobTitle\":\"Fondateur & consultant SEO\",\"url\":\"https://monsieurclick.fr/consultant-seo-paris\",\"worksFor\":{\"@id\":\"https://monsieurclick.fr/#org\"},\"description\":\"10 ans d'expérience en SEO et visibilité locale. Fondateur de Monsieur Click et de la méthode Click First™.\"},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"},\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://monsieurclick.fr/blog/?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}\n]}","{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"WebPage\", \"@id\": \"https://monsieurclick.fr/#webpage\", \"url\": \"https://monsieurclick.fr/\", \"name\": \"Agence SEO et Web Design à Paris | Monsieur Click — Malakoff (92)\", \"isPartOf\": {\"@id\": \"https://monsieurclick.fr/#website\"}, \"about\": {\"@id\": \"