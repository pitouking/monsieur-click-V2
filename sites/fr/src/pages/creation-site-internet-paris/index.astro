const jsonLd = ["{\n  \"@context\":\"https://schema.org\",\"@type\":\"Service\",\n  \"name\":\"Création de site internet à Paris\",\n  \"serviceType\":\"Création de site vitrine sur mesure, optimisé SEO et orienté conversion pour entreprises parisiennes\",\n  \"provider\":{\"@type\":\"ProfessionalService\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr\"},\n  \"areaServed\":{\"@type\":\"City\",\"name\":\"Paris\"},\n  \"description\":\"Création de site internet à Paris : design StoryBrand, Core Web Vitals au vert, SEO technique intégré et visibilité locale pour TPE et PME.\"\n}","{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[\n{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://monsieurclick.fr/\"},\n{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Création de site internet à Paris\",\"item\":\"https://monsieurclick.fr/creation-site-internet-paris\"}]}","{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[\n{\"@type\":\"Question\",\"name\":\"Combien coûte la création d'un site internet à Paris ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Un site vitrine optimisé SEO pour une TPE parisienne démarre autour de 2 500 à 4 500 € selon la complexité. Nous chiffrons après un diagnostic gratuit, avec un plan écrit et sans surprise. Pas de devis au kilomètre.\"}},\n{\"@type\":\"Question\",\"name\":\"Mon site sera-t-il visible sur Google à Paris ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Un site bien construit est indexable immédiatement. Le classement se construit sur plusieurs mois. Nous intégrons l'architecture SEO, le maillage interne, les données structurées et les Core Web Vitals dès la création, plus le SEO local pour Google Maps.\"}},\n{\"@type\":\"Question\",\"name\":\"WordPress ou site statique pour une TPE parisienne ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nous choisissons la stack selon vos besoins : WordPress si vous voulez éditer vous-même, Brizy Cloud pour un bon compromis design et autonomie, ou statique pour la performance maximale. Dans tous les cas, le SEO est intégré dès le départ.\"}},\n{\"@type\":\"Question\",\"name\":\"Travaillez-vous uniquement avec des entreprises à Paris ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nous accompagnons les entreprises basées à Paris et en Île-de-France, mais aussi partout en France, en Belgique et en Suisse, 100 % à distance. Notre siège est à Malakoff (92), à proximité immédiate de Paris.\"}},\n{\"@type\":\"Question\",\"name\":\"Le site inclut-il le référencement naturel ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui. Chaque site intègre le SEO technique dès la conception : balises optimisées, architecture claire, Schema.org, sitemap, Core Web Vitals. Pour accélérer les résultats, nous recommandons la méthode Click First™ qui relie site, SEO local et visibilité IA.\"}}\n]}","{\"@context\":\"https://schema.org\",\"@graph\":[\n{\"@type\":[\"Organization\",\"ProfessionalService\"],\"@id\":\"https://monsieurclick.fr/#org\",\"name\":\"Monsieur Click\",\"url\":\"https://monsieurclick.fr/\",\"logo\":\"https://monsieurclick.fr/logo-mc.webp\",\"email\":\"contact@monsieurclick.com\",\"telephone\":\"+33660761523\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"24 bis sentier des fosses rouges\",\"postalCode\":\"92240\",\"addressLocality\":\"Malakoff\",\"addressRegion\":\"Île-de-France\",\"addressCountry\":\"FR\"}},\n{\"@type\":\"WebSite\",\"@id\":\"https://monsieurclick.fr/#website\",\"url\":\"https://monsieurclick.fr/\",\"name\":\"Monsieur Click\",\"inLanguage\":\"fr-FR\",\"publisher\":{\"@id\":\"https://monsieurclick.fr/#org\"}}\n]}"];
const scripts = [{"src":"/perf.js?v=20260719perf","module":false},{"src":"/shared.js?v=20260719perf","module":false}];
---
<BaseLayout
